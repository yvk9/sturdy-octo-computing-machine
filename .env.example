# Copy this file to ".env" and adjust values, then run: docker compose up -d
# (Your real .env is gitignored and will NOT be committed.)

# Timezone for the n8n scheduler (use a tz database name)
TZ=America/New_York
GENERIC_TIMEZONE=America/New_York

# Internal URL n8n uses to reach Ollama (leave as-is for the bundled stack)
OLLAMA_HOST=http://ollama:11434

# n8n base config
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
